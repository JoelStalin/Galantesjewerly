# ============================================================================
# PRODUCCIÓN — Docker Compose Local + Cloudflare Tunnel
# ============================================================================
# IMPORTANTE: Este archivo debe poblarse con valores reales antes de desplegar
# Copiar con: cp .env.prod .env && edit .env (o usar docker-compose --env-file)

# ============================================================================
# CLOUDFLARE CONFIGURATION
# ============================================================================
# Los tokens se generan en Cloudflare Dashboard → Zero Trust → Tunnels
CF_TUNNEL_TOKEN_PROD=eyJzIjoiTHZtcG1xNk45K1JFRVFtb1Y1bWRDQko0UkVBT2IySElib2FaSDVEa05SST0iLCJ0IjoiOTM4MmVmODgtY2FhZC00YmRlLWI3YjctOGY4MzQzNDZkMzQ2IiwiYSI6ImVmY2U0MTc5YTdlZTk2YzE5YjQzYzQyYmNlZDU4NTg3In0=
CF_TUNNEL_TOKEN_TEST=your_cloudflare_tunnel_token_test_here
CF_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=your_cloudflare_account_id_here
CF_ZONE_ID=your_cloudflare_zone_id_here

# ============================================================================
# NEXT.JS WEB APPLICATION
# ============================================================================
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
APP_DATA_DIR=/app/data
NGINX_PORT=8080

# Admin credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_secure_password_32_chars_min
ADMIN_SECRET_KEY=generate_with_openssl_rand_base64_32
INTEGRATIONS_SECRET_KEY=generate_with_openssl_rand_base64_32
APPOINTMENT_ENCRYPTION_KEY=generate_with_openssl_rand_base64_32
GOOGLE_SESSION_SECRET=generate_with_openssl_rand_base64_32

# ============================================================================
# SITE CONFIGURATION (Public URLs — must match Cloudflare domains)
# ============================================================================
SITE_URL=https://galantesjewelry.com
NEXT_PUBLIC_SITE_URL=https://galantesjewelry.com
GOOGLE_PUBLIC_BASE_URL=https://galantesjewelry.com
SHOP_URL=https://shop.galantesjewelry.com
ODOO_URL=https://odoo.galantesjewelry.com

# ============================================================================
# ODOO BACKEND (Docker Internal URLs)
# ============================================================================
ODOO_BASE_URL=http://odoo:8069
NEXT_PUBLIC_ODOO_SHOP_URL=https://shop.galantesjewelry.com
ODOO_DB=galantes_db
ODOO_USERNAME=admin
ODOO_PASSWORD=change_me_odoo_password_secure
ODOO_AUTO_INSTALL_MODULES=true
ODOO_API_KEY=
ODOO_WEBSITE_ID=1
ODOO_COMPANY_ID=1
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me_postgres_password_secure

# ============================================================================
# GOOGLE OAUTH (Calendar + Authentication)
# ============================================================================
GOOGLE_OAUTH_client_id=GOOGLE_CLIENT_ID
GOOGLE_OAUTH_client_secret=GOOGLE_SECRET
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_JAVASCRIPT_ORIGIN=https://galantesjewelry.com
GOOGLE_OAUTH_REDIRECT_URI=https://galantesjewelry.com/auth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile

client_id=GOOGLE_CLIENT_ID
client_secret=GOOGLE_SECRET
REDIRECT_URI=https://galantesjewelry.com/api/v1/google/oauth/callback

# Google Calendar
GOOGLE_CALENDAR_ID=primary_or_shared_calendar_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=calendar-bot@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n

# ============================================================================
# EMAIL CONFIGURATION (Gmail SMTP + SendGrid)
# ============================================================================
GMAIL_SMTP_USER=joelstalin2105@gmail.com
GMAIL_SMTP_PASS=your_gmail_app_password
GMAIL_NOTIFICATION_TO=ceo@galantesjewelry.com

SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@galantesjewelry.com
SENDGRID_ADMIN_TO=ceo@galantesjewelry.com
SENDGRID_APPOINTMENT_SUBJECT=Galantes Jewelry Appointment Confirmation

# ============================================================================
# META / FACEBOOK / INSTAGRAM / WHATSAPP
# ============================================================================
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_CATALOG_ID=
META_VERIFY_TOKEN=
META_SYNC_TOKEN=your-secure-meta-sync-token-change-me
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ============================================================================
# APPOINTMENT SYSTEM (Multi-CLI Orchestration)
# ============================================================================
ODOO_ENABLED=true
ODOO_TIMEOUT_MS=30000
ODOO_SYNC_ON_APPOINTMENT_VALIDATED=true

MODEL_PROVIDER_ORDER=claude_code,codex_cli,gemini_cli
CLAUDE_CODE_ENABLED=true
CODEX_CLI_ENABLED=true
GEMINI_CLI_ENABLED=true
CLAUDE_CODE_CMD=claude
CODEX_CLI_CMD=codex
GEMINI_CLI_CMD=gemini
CLI_TASK_TIMEOUT_MS=900000
CLI_MAX_RETRIES_PER_PROVIDER=2
CLI_COOLDOWN_ON_RATE_LIMIT_MS=60000
CLI_CHECKPOINT_DIR=./task-ledger/checkpoints
CLI_HANDOFF_STRATEGY=continue_from_last_checkpoint
CLI_REQUIRE_STRUCTURED_OUTPUT=true
CLI_AUDIT_LOG_ENABLED=true

# ============================================================================
# MEMORY SYSTEM
# ============================================================================
MEMORY_ROOT=./memory
MEMORY_ENABLE_CURATION=true
MEMORY_SESSION_SUMMARY_MAX_CHARS=6000
MEMORY_HOT_MAX_LINES=200
MEMORY_REDACT_SECRETS=true
MEMORY_REBUILD_AGENT_CONTEXT_ON_CHANGE=true

# ============================================================================
# TASK LEDGER
# ============================================================================
TASK_LEDGER_ROOT=./task-ledger
TASK_LEDGER_ENABLE_AUDIT=true

# ============================================================================
# LOGGING & SECURITY
# ============================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
CORS_ORIGINS=https://galantesjewelry.com,https://www.galantesjewelry.com,https://shop.galantesjewelry.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=8

# ============================================================================
# TESTING (Local Dev — puede estar vacío en producción)
# ============================================================================
E2E_BASE_URL=http://127.0.0.1:3000
SELENIUM_PROFILE=Default
SELENIUM_HEADLESS=0

# ============================================================================
# REMOTE DEPLOYMENT (Opcional — para CI/CD futuro)
# ============================================================================
REMOTE_HOST=your.server.ip
REMOTE_PORT=22
REMOTE_USER=ubuntu
REMOTE_APP_DIR=/var/www/galantesjewelry

# ============================================================================
# TOKEN PATHS
# ============================================================================
GOOGLE_TOKEN_PATH=./token.json
