# === ODOO BACKEND (§3 Integration) ===
ODOO_BASE_URL=http://odoo:8069
ODOO_PUBLIC_SHOP_URL=https://shop.galantesjewelry.com
ODOO_DB=galantes_db
ODOO_USERNAME=admin
ODOO_PASSWORD=admin
ODOO_API_KEY=
