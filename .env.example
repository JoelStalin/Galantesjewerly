ODOO_COMPANY_ID=1

# === META / FACEBOOK / INSTAGRAM / WHATSAPP (§3 Integration) ===
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_CATALOG_ID=
META_VERIFY_TOKEN=
META_SYNC_TOKEN=your-secure-sync-token-change-me

# === APPOINTMENT SYSTEM (Mega Prompt Maestro v3) ===

# Google Calendar API v3
CLIENT_ID=your_google_client_id_here
CLIENT_SECRET=your_google_client_secret_here
REDIRECT_URI=http://localhost:3000/api/auth/google/callback
TOKEN_PATH=./token.json

# SendGrid for Email Notifications
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@galantesjewelry.com

# Odoo Integration (JSON-2 API)
ODOO_ENABLED=true
ODOO_BASE_URL=http://localhost:8069
ODOO_DATABASE=galantes_db
ODOO_API_KEY=your_odoo_api_key_here
ODOO_TIMEOUT_MS=30000
ODOO_SYNC_ON_APPOINTMENT_VALIDATED=true

# Multi-CLI Orchestration
MODEL_PROVIDER_ORDER=claude_code,codex_cli,gemini_cli
CLAUDE_CODE_ENABLED=true
CODEX_CLI_ENABLED=true
GEMINI_CLI_ENABLED=true
CLAUDE_CODE_CMD=claude
CODEX_CLI_CMD=codex
GEMINI_CLI_CMD=gemini
CLI_TASK_TIMEOUT_MS=900000
CLI_MAX_RETRIES_PER_PROVIDER=2
CLI_COOLDOWN_ON_RATE_LIMIT_MS=60000
CLI_CHECKPOINT_DIR=./task-ledger/checkpoints
CLI_HANDOFF_STRATEGY=continue_from_last_checkpoint
CLI_REQUIRE_STRUCTURED_OUTPUT=true
CLI_AUDIT_LOG_ENABLED=true

# Memory System
MEMORY_ROOT=./memory
MEMORY_ENABLE_CURATION=true
MEMORY_SESSION_SUMMARY_MAX_CHARS=6000
MEMORY_HOT_MAX_LINES=200
MEMORY_REDACT_SECRETS=true
MEMORY_REBUILD_AGENT_CONTEXT_ON_CHANGE=true

# Task Ledger
TASK_LEDGER_ROOT=./task-ledger
TASK_LEDGER_ENABLE_AUDIT=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Security
CORS_ORIGINS=http://localhost:3000,https://galantesjewelry.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=8
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# === SHOP URLS (§3 Integration) ===
SHOP_URL=https://shop.galantesjewelry.com
ODOO_URL=https://odoo.galantesjewelry.com
