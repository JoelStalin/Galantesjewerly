# =========================================================================
# GCP PRODUCTION .env — Galante's Jewelry
# =========================================================================
# Este archivo define las variables que usa docker-compose.gcp.yml.
# Copialo a .env.gcp y rellenalo:
#   cp .env.gcp.example .env.gcp && nano .env.gcp
#
# Cualquier valor que empiece con CHANGE_ o contenga <placeholder> DEBE ser
# reemplazado antes de ejecutar scripts/gcp/deploy.sh.
#
# Guia para obtener cada secreto: docs/deployment/SECRETS_CHECKLIST.md
# =========================================================================

# -------------------- GCP PROJECT / INFRASTRUCTURE --------------------
GCP_PROJECT_ID=deft-haven-493016-m4
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCP_VM_NAME=galantes-prod-vm
GCP_VM_EXTERNAL_IP=136.114.48.210
GCP_VM_USER=ubuntu
GCP_VM_REPO_DIR=/home/ubuntu/galantesjewelry

# -------------------- DNS / CLOUDFLARE --------------------
# Nameservers son de Cloudflare (aunque el registrar sea Squarespace).
# Necesitas un API Token con permiso Zone:DNS:Edit para galantesjewelry.com
CF_API_TOKEN=CHANGE_ME_cloudflare_api_token_with_DNS_edit_scope
CF_ZONE_NAME=galantesjewelry.com
CF_ZONE_ID=CHANGE_ME_zone_id_from_cloudflare_overview

# Hosts que apuntaran a la VM de GCP (A records proxy=false durante cert issue)
GCP_HOSTNAMES=galantesjewelry.com www.galantesjewelry.com shop.galantesjewelry.com odoo.galantesjewelry.com

# -------------------- LET'S ENCRYPT --------------------
LETSENCRYPT_EMAIL=joelstalin2105@gmail.com
# staging=1 emite certs de prueba (no son validos pero no cuentan al rate limit)
LETSENCRYPT_STAGING=0

# -------------------- NEXT.JS ADMIN --------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_openssl_rand_base64_24
ADMIN_SECRET_KEY=CHANGE_ME_openssl_rand_base64_32
INTEGRATIONS_SECRET_KEY=CHANGE_ME_openssl_rand_base64_32
APPOINTMENT_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_base64_32
GOOGLE_SESSION_SECRET=CHANGE_ME_openssl_rand_base64_32

# -------------------- PUBLIC URLS --------------------
SITE_URL=https://galantesjewelry.com
NEXT_PUBLIC_SITE_URL=https://galantesjewelry.com
GOOGLE_PUBLIC_BASE_URL=https://galantesjewelry.com
SHOP_URL=https://shop.galantesjewelry.com
ODOO_URL=https://odoo.galantesjewelry.com
NEXT_PUBLIC_ODOO_SHOP_URL=https://shop.galantesjewelry.com

# -------------------- ODOO BACKEND --------------------
ODOO_ENABLED=true
ODOO_BASE_URL=http://odoo:8069
ODOO_DB=galantes_prod
ODOO_USERNAME=admin
ODOO_PASSWORD=CHANGE_ME_odoo_admin_password
ODOO_API_KEY=CHANGE_ME_odoo_api_key_for_json2
ODOO_WEBSITE_ID=1
ODOO_COMPANY_ID=1
ODOO_TIMEOUT_MS=30000
ODOO_SYNC_ON_APPOINTMENT_VALIDATED=true
ODOO_AUTO_INSTALL_MODULES=true
POSTGRES_USER=odoo
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_min32chars

# -------------------- GOOGLE OAUTH (Login + Calendar) --------------------
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME_google_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_JAVASCRIPT_ORIGIN=https://galantesjewelry.com
GOOGLE_OAUTH_REDIRECT_URI=https://galantesjewelry.com/auth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile

CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
CLIENT_SECRET=CHANGE_ME_google_oauth_client_secret
REDIRECT_URI=https://galantesjewelry.com/api/v1/google/oauth/callback

GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_EMAIL=calendar-bot@deft-haven-493016-m4.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"

# -------------------- EMAIL (SendGrid + Gmail SMTP fallback) --------------------
SENDGRID_API_KEY=CHANGE_ME_SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@galantesjewelry.com
SENDGRID_ADMIN_TO=ceo@galantesjewelry.com
SENDGRID_APPOINTMENT_SUBJECT=Galantes Jewelry Appointment Confirmation

GMAIL_SMTP_USER=joelstalin2105@gmail.com
GMAIL_SMTP_PASS=CHANGE_ME_gmail_app_password_16chars
GMAIL_NOTIFICATION_TO=ceo@galantesjewelry.com

# -------------------- META / FACEBOOK / INSTAGRAM --------------------
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_CATALOG_ID=
META_VERIFY_TOKEN=
META_SYNC_TOKEN=CHANGE_ME_openssl_rand_base64_24
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# -------------------- SECURITY --------------------
CORS_ORIGINS=https://galantesjewelry.com,https://www.galantesjewelry.com,https://shop.galantesjewelry.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=8
LOG_LEVEL=info

# -------------------- DATA MIGRATION (Termux source) --------------------
# Opcional. Usado por scripts/gcp/06-migrate-data-from-termux.sh
# Puedes dejarlo vacio y el script preguntara interactivamente.
TERMUX_SSH_HOST=
TERMUX_SSH_USER=u0_a123
TERMUX_SSH_PORT=8022
TERMUX_ODOO_DB_DUMP_PATH=/data/data/com.termux/files/home/backup/galantes_prod.sql
TERMUX_DATA_BLOBS_PATH=/data/data/com.termux/files/home/galantesjewelry/data
