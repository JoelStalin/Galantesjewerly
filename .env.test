# ============================================================================
# TESTING — Termux Android + Cloudflare Tunnel TEST
# ============================================================================
# IMPORTANTE: Este archivo es para la rama de TESTING (Termux)
# Copiar con: cp .env.test.example .env.test && edit .env.test

# ============================================================================
# CLOUDFLARE CONFIGURATION (TEST TUNNEL)
# ============================================================================
# Token específico para el túnel de TEST
CF_TUNNEL_TOKEN_TEST=your_cloudflare_tunnel_token_test_here

# ============================================================================
# NEXT.JS WEB APPLICATION
# ============================================================================
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
APP_DATA_DIR=./data

# Admin credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_test_password
ADMIN_SECRET_KEY=test_secret_key_32_chars_minimum_required
INTEGRATIONS_SECRET_KEY=test_integration_secret_key_32_chars
APPOINTMENT_ENCRYPTION_KEY=test_appointment_secret_key_32_chars
GOOGLE_SESSION_SECRET=test_google_session_secret_32_chars

# ============================================================================
# SITE CONFIGURATION (Test URLs)
# ============================================================================
SITE_URL=https://test.galantesjewelry.com
NEXT_PUBLIC_SITE_URL=https://test.galantesjewelry.com
GOOGLE_PUBLIC_BASE_URL=https://test.galantesjewelry.com

# ============================================================================
# ODOO BACKEND (TEST - Sin Docker, servicio externo)
# ============================================================================
# En TEST (Termux), Odoo puede ser:
# 1. Instancia remota: ODOO_BASE_URL=https://odoo-test.server.com
# 2. Local en Termux: ODOO_BASE_URL=http://127.0.0.1:8069
# 3. Docker en computadora host: ODOO_BASE_URL=http://192.168.x.x:8069

ODOO_BASE_URL=http://127.0.0.1:8069
NEXT_PUBLIC_ODOO_SHOP_URL=https://test-shop.galantesjewelry.com
ODOO_DB=galantes_db_test
ODOO_USERNAME=admin
ODOO_PASSWORD=admin_test_password
ODOO_API_KEY=
ODOO_WEBSITE_ID=1
ODOO_COMPANY_ID=1

# ============================================================================
# GOOGLE OAUTH (Testing)
# ============================================================================
GOOGLE_OAUTH_client_id=GOOGLE_CLIENT_ID
GOOGLE_OAUTH_client_secret=GOOGLE_SECRET
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_JAVASCRIPT_ORIGIN=https://test.galantesjewelry.com
GOOGLE_OAUTH_REDIRECT_URI=https://test.galantesjewelry.com/auth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile

client_id=GOOGLE_CLIENT_ID
client_secret=GOOGLE_SECRET
REDIRECT_URI=https://test.galantesjewelry.com/api/v1/google/oauth/callback

GOOGLE_CALENDAR_ID=test_calendar_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=test-calendar-bot@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\ntest_key_here\n-----END PRIVATE KEY-----\n

# ============================================================================
# EMAIL CONFIGURATION (Testing)
# ============================================================================
GMAIL_SMTP_USER=test@gmail.com
GMAIL_SMTP_PASS=test_gmail_password
GMAIL_NOTIFICATION_TO=test@galantesjewelry.com

SENDGRID_API_KEY=test_sendgrid_key
SENDGRID_FROM_EMAIL=test-noreply@galantesjewelry.com
SENDGRID_ADMIN_TO=test-admin@galantesjewelry.com
SENDGRID_APPOINTMENT_SUBJECT=TEST - Galantes Jewelry Appointment

# ============================================================================
# META / FACEBOOK / INSTAGRAM / WHATSAPP (Testing)
# ============================================================================
META_APP_ID=test_meta_app_id
META_APP_SECRET=test_meta_secret
META_ACCESS_TOKEN=test_meta_token
META_CATALOG_ID=test_catalog_id
META_VERIFY_TOKEN=test_verify_token
META_SYNC_TOKEN=test_sync_token_change_me

# ============================================================================
# APPOINTMENT SYSTEM
# ============================================================================
ODOO_ENABLED=false
ODOO_TIMEOUT_MS=30000

MODEL_PROVIDER_ORDER=claude_code
CLAUDE_CODE_ENABLED=true

# ============================================================================
# MEMORY SYSTEM
# ============================================================================
MEMORY_ROOT=./memory
MEMORY_ENABLE_CURATION=true
MEMORY_SESSION_SUMMARY_MAX_CHARS=6000

# ============================================================================
# LOGGING & SECURITY
# ============================================================================
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
CORS_ORIGINS=https://test.galantesjewelry.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# TESTING
# ============================================================================
E2E_BASE_URL=http://127.0.0.1:3000
SELENIUM_PROFILE=Default
SELENIUM_HEADLESS=0

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
# - Este archivo es para desarrollo/testing en Termux
# - No debe contener secretos reales (usar testing credentials)
# - Los logs se guardan en ./logs/
# - Cloudflared se inicia automáticamente en background
# - Para ver cambios, reinicia con: ./scripts/deploy-test.sh
